---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";
---

<Base
    title="Sobre - Sigel | Quem Somos, Nossa Missão e História"
    description="Conheça a Sigel Soluções em Informática. Desde 2018 ajudamos PMEs a crescer no digital com tecnologia, design e copywriting estratégico."
    canonical="/sobre"
>
    <Header client:load />

    <main
        <main
        class="flex-1 flex flex-col pb-20 md:pb-32 max-w-7xl mx-auto w-full md:px-12 pt-12 md:pt-0"
    >
        {/* Hero Section with Image */}
        <div class="px-5 py-6">
            <div
                class="relative w-full aspect-[4/3] overflow-hidden rounded-xl shadow-sm mb-6 bg-gray-200"
            >
                <img
                    alt="Equipe Sigel Soluções em Informática"
                    class="w-full h-full object-cover"
                    src="/images/quemsomos.jpeg"
                />

                {/* Gradient Overlay */}
                <div
                    class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent flex flex-col justify-end p-6 md:p-8"
                >
                    <span
                        class="inline-block px-4 py-1.5 bg-primary text-text-main text-xs font-black rounded-full w-fit mb-3 uppercase tracking-wider"
                    >
                        Desde 2018
                    </span>

                    <h1
                        class="text-white text-3xl md:text-5xl font-bold leading-tight tracking-tight"
                    >
                        Construindo Pontes Digitais para PMEs
                    </h1>
                </div>
            </div>

            {/* Text Content */}
            <div class="space-y-6 md:px-4 py-4">
                <h2
                    class="text-2xl md:text-3xl font-bold text-white tracking-tight"
                >
                    Nossa História
                </h2>

                <p class="text-gray-300 text-lg leading-relaxed">
                    A Sigel Soluções em Informática nasceu com uma missão clara:
                    descomplicar a tecnologia e o marketing para pequenas e
                    médias empresas.
                </p>

                <p class="text-gray-300 text-lg leading-relaxed">
                    Em um mundo cada vez mais digital, percebemos que muitos
                    empreendedores se sentiam perdidos. Decidimos ser o parceiro
                    que traduz "tecnês" para resultados reais de negócios,
                    unindo design de altíssimo padrão, tecnologia de ponta e
                    copywriting focado inteiramente em conversão.
                </p>
            </div>
        </div>

        {/* Our Reach Section */}
        <div
            class="bg-surface-dark py-12 px-5 md:px-12 my-6 md:rounded-[2rem] border-y md:border border-gray-800 shadow-sm"
        >
            <div class="flex flex-col md:flex-row gap-8 items-center">
                <div class="w-full">
                    <div class="flex items-center justify-center gap-3 mb-6">
                        <div
                            class="p-2.5 bg-accent text-white rounded-xl shadow-lg shadow-accent/20"
                        >
                            <span class="material-symbols-outlined text-3xl"
                                >public</span
                            >
                        </div>
                        <h2
                            class="text-2xl font-bold text-white tracking-tight"
                        >
                            Nosso Alcance
                        </h2>
                    </div>

                    <p
                        class="text-lg text-gray-400 leading-relaxed mb-6 text-center max-w-3xl mx-auto"
                    >
                        Focados em elevar o patamar de Pequenas e Médias
                        Empresas (PMEs) de norte a sul do país, garantindo
                        suporte remoto impecável e presença dedicada em capitais
                        selecionadas. Atuamos em todo o Brasil.
                    </p>
                </div>
            </div>
        </div>

        {/* Our Philosophy Section */}
        <div class="px-5 md:px-9 py-10">
            <h2
                class="text-2xl md:text-3xl font-bold text-white mb-8 tracking-tight"
            >
                Nossa Filosofia
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {/* Card 1: Clareza Absoluta */}
                <div
                    class="flex flex-col gap-4 p-8 rounded-2xl bg-surface-dark border border-gray-800 shadow-sm hover:border-primary/50 transition-colors group"
                >
                    <div
                        class="shrink-0 flex items-center justify-center size-14 rounded-xl bg-accent text-white shadow-lg shadow-accent/20 group-hover:scale-110 transition-transform"
                    >
                        <span class="material-symbols-outlined text-3xl"
                            >visibility</span
                        >
                    </div>

                    <div>
                        <h3 class="font-bold text-xl text-white mb-2">
                            Clareza Absoluta
                        </h3>
                        <p class="text-base text-gray-400 leading-relaxed">
                            Transformamos processos complexos em planos de ação
                            simples, educando nossos clientes em cada passo da
                            jornada.
                        </p>
                    </div>
                </div>

                {/* Card 2: Foco em Conversão */}
                <div
                    class="flex flex-col gap-4 p-8 rounded-2xl bg-surface-dark border border-gray-800 shadow-sm hover:border-primary/50 transition-colors group"
                >
                    <div
                        class="shrink-0 flex items-center justify-center size-14 rounded-xl bg-accent text-white shadow-lg shadow-accent/20 group-hover:scale-110 transition-transform"
                    >
                        <span class="material-symbols-outlined text-3xl"
                            >trending_up</span
                        >
                    </div>

                    <div>
                        <h3 class="font-bold text-xl text-white mb-2">
                            Foco em Conversão
                        </h3>
                        <p class="text-base text-gray-400 leading-relaxed">
                            Não fazemos "arte pela arte". Todo design, texto e
                            código que sai das nossas mãos é intencionalmente
                            focado em gerar crescimento comercial.
                        </p>
                    </div>
                </div>

                {/* Card 3: Parceria Real */}
                <div
                    class="flex flex-col gap-4 p-8 rounded-2xl bg-surface-dark border border-gray-800 shadow-sm hover:border-primary/50 transition-colors group"
                >
                    <div
                        class="shrink-0 flex items-center justify-center size-14 rounded-xl bg-accent text-white shadow-lg shadow-accent/20 group-hover:scale-110 transition-transform"
                    >
                        <span class="material-symbols-outlined text-3xl"
                            >support_agent</span
                        >
                    </div>

                    <div>
                        <h3 class="font-bold text-xl text-white mb-2">
                            Parceria Real
                        </h3>
                        <p class="text-base text-gray-400 leading-relaxed">
                            Somos parceiros estratégicos, não apenas
                            fornecedores executores. Celebramos cada venda do
                            seu negócio como se fosse nossa.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        {/* Final CTA Section */}
        <div
            class="mx-5 md:mx-0 my-12 p-8 md:p-14 lg:p-16 rounded-[2rem] bg-gradient-to-br from-[#1c1540] to-secondary text-white shadow-2xl flex flex-col md:flex-row items-center justify-between gap-8 md:gap-16 relative overflow-hidden group"
        >
            {/* Blur Background */}
            <div
                class="absolute top-0 right-0 w-96 h-96 bg-accent/15 rounded-full blur-3xl group-hover:bg-accent/25 transition-colors duration-700 pointer-events-none"
            >
            </div>

            {/* Text Content */}
            <div
                class="relative z-10 w-full md:w-[60%] flex flex-col gap-4 md:gap-5"
            >
                <h2
                    class="text-3xl md:text-5xl lg:text-5xl font-bold tracking-tight leading-[1.15]"
                >
                    Pronto para finalmente <br class="hidden md:block" />
                    crescer no digital?
                </h2>

                <p
                    class="text-gray-300 text-lg max-w-lg leading-relaxed opacity-90"
                >
                    Agende uma conversa detalhada e sem compromisso para
                    descobrir o real potencial de conversão da sua empresa.
                </p>
            </div>

            {/* CTA Button */}
            <div class="relative z-10 w-full md:w-[40%] flex md:justify-end">
                <a
                    href="https://wa.me/555191305583?text=Ol%C3%A1%21%20Estava%20no%20site%20da%20Sigel%20e%20gostaria%20de%20solicitar%20um%20diagn%C3%B3stico%20gratuito%20para%20o%20meu%20neg%C3%B3cio."
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full md:w-auto py-5 px-8 md:px-10 bg-accent hover:bg-accent-dark text-white font-bold text-lg md:text-xl rounded-xl shadow-[0_0_25px_rgba(246,94,55,0.4)] transition-all hover:scale-105 active:scale-95 flex items-center justify-center gap-3"
                >
                    <span class="material-symbols-outlined text-[28px]"
                        >rocket_launch</span
                    >
                    <span>Falar com nosso Consultor</span>
                </a>
            </div>
        </div>
    </main>

    <Footer />
</Base>
