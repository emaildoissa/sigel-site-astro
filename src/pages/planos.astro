---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.tsx";
import Footer from "../components/Footer.astro";

// Dados de capacidade
const totalVagas = 8;
const filledVagas = 6;
const progressPercent = Math.round((filledVagas / totalVagas) * 100);
---

<Base
    title="Planos - Sigel | Preços, Prazos e Capacidade de Projetos"
    description="Conheça nossos planos, prazos de entrega e como funcionam nossos processos. Transparência em primeiro lugar. 8 vagas de projetos simultâneos."
    canonical="/planos"
>
    <Header client:load />

    <main
        class="flex-1 w-full max-w-7xl mx-auto px-5 md:px-12 md:pt-16 md:pb-24 flex flex-col gap-12 md:gap-20"
    >
        {/* ===== HERO SECTION ===== */}
        <section
            class="flex flex-col md:flex-row md:items-end justify-between gap-6 md:gap-12"
        >
            <div class="md:w-2/3">
                <h1
                    class="text-3xl md:text-5xl lg:text-6xl font-bold leading-tight tracking-tight text-white mb-4"
                >
                    Como funcionam <br class="hidden md:block" />
                    <span class="text-primary relative inline-block md:mt-2">
                        nossos processos
                        <span
                            class="absolute bottom-1 md:bottom-2 left-0 w-full h-3 md:h-5 bg-primary/20 -z-10 rounded-sm"
                        ></span>
                    </span>
                </h1>

                <p
                    class="text-gray-300 text-lg md:text-xl leading-relaxed max-w-2xl"
                >
                    Transparência em primeiro lugar. Entenda exatamente o que
                    define o investimento e nossos prazos médios de entrega para
                    cada tipo de solução.
                </p>
            </div>

            <div class="hidden md:block w-1/3">
                <div
                    class="bg-surface-dark p-6 rounded-2xl border border-gray-800 shadow-sm flex flex-col gap-2"
                >
                    <span
                        class="text-sm font-bold tracking-wider text-primary uppercase"
                        >Qualidade acima de tudo</span
                    >
                    <p class="text-gray-300 font-medium">
                        Não trabalhamos com templates focados em volume
                        comercial, entregamos peças artesanais voltadas pra
                        perfomance real.
                    </p>
                </div>
            </div>
        </section>

        {/* ===== TWO COLUMN LAYOUT ===== */}
        <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-start">
            {/* LEFT: Pricing Variables */}
            <section class="w-full md:w-1/2 flex flex-col gap-6">
                <h2 class="text-2xl font-bold tracking-tight text-white">
                    O que define o investimento?
                </h2>

                <div class="grid grid-cols-1 gap-4">
                    {/* Card 1: Design Complexity */}
                    <div
                        class="flex items-start p-5 md:p-6 bg-surface-dark rounded-2xl border border-gray-800 shadow-sm hover:border-primary/50 transition-colors group"
                    >
                        <div
                            class="flex-shrink-0 size-12 md:size-14 rounded-xl bg-accent flex items-center justify-center text-white mr-5 shadow-lg shadow-accent/20 group-hover:scale-110 transition-transform"
                        >
                            <span
                                class="material-symbols-outlined text-2xl md:text-3xl"
                                >design_services</span
                            >
                        </div>

                        <div>
                            <h3 class="font-bold text-lg text-white mb-1">
                                Complexidade do Design
                            </h3>
                            <p class="text-sm text-gray-400 leading-relaxed">
                                Layouts exclusivos, ilustrações 3D e animações
                                personalizadas de alto padrão exigem um tempo
                                consideravelmente maior de desenvolvimento na
                                prancheta.
                            </p>
                        </div>
                    </div>

                    {/* Card 2: System Integrations */}
                    <div
                        class="flex items-start p-5 md:p-6 bg-surface-dark rounded-2xl border border-gray-800 shadow-sm hover:border-primary/50 transition-colors group"
                    >
                        <div
                            class="flex-shrink-0 size-12 md:size-14 rounded-xl bg-accent flex items-center justify-center text-white mr-5 shadow-lg shadow-accent/20 group-hover:scale-110 transition-transform"
                        >
                            <span
                                class="material-symbols-outlined text-2xl md:text-3xl"
                                >integration_instructions</span
                            >
                        </div>

                        <div>
                            <h3 class="font-bold text-lg text-white mb-1">
                                Integrações Sistêmicas
                            </h3>
                            <p class="text-sm text-gray-400 leading-relaxed">
                                Conexões nativas com CRM, APIs externas, meios
                                de pagamento e gatilhos de automação aumentam o
                                escopo técnico e a exigência de testes do
                                projeto.
                            </p>
                        </div>
                    </div>

                    {/* Card 3: Urgency Rate */}
                    <div
                        class="flex items-start p-5 md:p-6 bg-surface-dark rounded-2xl border border-gray-800 shadow-sm hover:border-primary/50 transition-colors group"
                    >
                        <div
                            class="flex-shrink-0 size-12 md:size-14 rounded-xl bg-accent flex items-center justify-center text-white mr-5 shadow-lg shadow-accent/20 group-hover:scale-110 transition-transform"
                        >
                            <span
                                class="material-symbols-outlined text-2xl md:text-3xl"
                                >rocket_launch</span
                            >
                        </div>

                        <div>
                            <h3 class="font-bold text-lg text-white mb-1">
                                Taxa de Urgência
                            </h3>
                            <p class="text-sm text-gray-400 leading-relaxed">
                                Prazos apertados requerem alocação prioritária
                                do mapa de horas da nossa equipe e horas extras
                                noturnas, impactando proporcionalmente no valor
                                final.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            {/* RIGHT: Timeline & Capacity */}
            <div class="w-full md:w-1/2 flex flex-col gap-10">
                {/* Timeline Estimates */}
                <section class="flex flex-col gap-6">
                    <div class="flex items-center justify-between">
                        <h2
                            class="text-2xl font-bold tracking-tight text-white"
                        >
                            Estimativa de Prazos
                        </h2>
                        <span
                            class="text-xs font-bold px-3 py-1.5 bg-primary/20 text-primary rounded-lg uppercase tracking-wider hidden sm:block"
                            >Baseado em histórico</span
                        >
                    </div>

                    <div
                        class="divide-y divide-gray-800 rounded-2xl border border-gray-800 bg-surface-dark overflow-hidden shadow-sm"
                    >
                        {/* Timeline Item 1 */}
                        <div
                            class="group p-5 md:p-6 flex items-center justify-between hover:bg-primary/5 transition-colors cursor-pointer"
                        >
                            <div class="flex items-center gap-4">
                                <span
                                    class="material-symbols-outlined text-gray-400 text-2xl group-hover:text-primary transition-colors"
                                    >web</span
                                >
                                <span
                                    class="font-bold text-white text-base md:text-lg"
                                    >Website Institucional</span
                                >
                            </div>
                            <span
                                class="text-sm md:text-base font-black text-primary bg-black/30 px-3 py-1 rounded-md"
                                >15-20 dias</span
                            >
                        </div>

                        {/* Timeline Item 2 */}
                        <div
                            class="group p-5 md:p-6 flex items-center justify-between hover:bg-primary/5 transition-colors cursor-pointer"
                        >
                            <div class="flex items-center gap-4">
                                <span
                                    class="material-symbols-outlined text-gray-400 text-2xl group-hover:text-primary transition-colors"
                                    >shopping_cart</span
                                >
                                <span
                                    class="font-bold text-white text-base md:text-lg"
                                    >E-commerce / Lojas</span
                                >
                            </div>
                            <span
                                class="text-sm md:text-base font-black text-primary bg-black/30 px-3 py-1 rounded-md"
                                >30-45 dias</span
                            >
                        </div>

                        {/* Timeline Item 3 */}
                        <div
                            class="group p-5 md:p-6 flex items-center justify-between hover:bg-primary/5 transition-colors cursor-pointer"
                        >
                            <div class="flex items-center gap-4">
                                <span
                                    class="material-symbols-outlined text-gray-400 text-2xl group-hover:text-primary transition-colors"
                                    >palette</span
                                >
                                <span
                                    class="font-bold text-white text-base md:text-lg"
                                    >Branding Completo</span
                                >
                            </div>
                            <span
                                class="text-sm md:text-base font-black text-primary bg-black/30 px-3 py-1 rounded-md"
                                >20-25 dias</span
                            >
                        </div>

                        {/* Timeline Item 4 */}
                        <div
                            class="group p-5 md:p-6 flex items-center justify-between hover:bg-primary/5 transition-colors cursor-pointer"
                        >
                            <div class="flex items-center gap-4">
                                <span
                                    class="material-symbols-outlined text-gray-400 text-2xl group-hover:text-primary transition-colors"
                                    >campaign</span
                                >
                                <span
                                    class="font-bold text-white text-base md:text-lg"
                                    >Automação & Copy</span
                                >
                            </div>
                            <span
                                class="text-sm md:text-base font-black text-primary bg-black/30 px-3 py-1 rounded-md"
                                >10-15 dias</span
                            >
                        </div>
                    </div>
                </section>

                {/* Capacity Section with Progress Bar */}
                <section
                    class="relative overflow-hidden rounded-3xl bg-surface-dark border border-primary/30 p-8 shadow-[0_0_30px_rgba(246,94,55,0.1)] transition-all hover:bg-surface-dark/80"
                >
                    <div
                        class="absolute -top-10 -right-10 w-48 h-48 bg-primary/10 rounded-full blur-3xl pointer-events-none"
                    >
                    </div>

                    <div class="relative z-10">
                        <div class="flex items-center gap-2 mb-3">
                            <span
                                class="flex h-2.5 w-2.5 rounded-full bg-primary animate-pulse"
                            ></span>
                            <span
                                class="text-xs font-bold uppercase tracking-widest text-primary"
                                >Status da Agenda: Alta Demanda</span
                            >
                        </div>

                        <h2
                            class="text-2xl md:text-3xl font-black text-white mb-3 tracking-tight"
                        >
                            Capacidade de Operação
                        </h2>

                        <p class="text-base text-gray-300 mb-8 leading-relaxed">
                            Para garantir a máxima performance e suporte
                            individualizado, limitamos nossa entrada a apenas <strong
                                >8 projetos simultâneos.</strong
                            >
                        </p>

                        {/* Progress Bar Container */}
                        <div class="space-y-4">
                            <div class="flex justify-between items-end">
                                <div class="flex flex-col">
                                    <span
                                        class="text-sm font-bold text-gray-400 uppercase tracking-tighter"
                                        >Ocupação Atual</span
                                    >
                                    <span class="text-2xl font-black text-white"
                                        >{progressPercent}%</span
                                    >
                                </div>
                                <div class="text-right">
                                    <span
                                        class="block text-xs font-bold text-primary uppercase animate-bounce text-[10px] md:text-xs"
                                        >Resta apenas {totalVagas - filledVagas} vagas</span
                                    >
                                    <span
                                        class="text-gray-500 text-xs md:text-sm font-medium"
                                        >{filledVagas} de {totalVagas} projetos em
                                        curso</span
                                    >
                                </div>
                            </div>

                            {/* Progress Bar with Shimmer */}
                            <div
                                class="w-full bg-black/50 rounded-full h-8 overflow-hidden shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)] relative border border-white/5"
                            >
                                <div
                                    class="bg-primary h-full rounded-full relative overflow-hidden transition-all duration-1000 ease-out shadow-[0_0_20px_rgba(246,94,55,0.4)]"
                                    style={`width: ${progressPercent}%`}
                                >
                                    {/* Shimmer Effect */}
                                    <div
                                        class="absolute inset-0 w-full h-full animate-shimmer"
                                        style="background-image: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent); background-size: 200% 100%;"
                                    >
                                    </div>
                                </div>
                            </div>

                            <p
                                class="text-[11px] md:text-[13px] text-gray-400 italic text-center"
                            >
                                *Atualizado em tempo real com base no roadmap da
                                equipe.
                            </p>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        {/* ===== DESKTOP CTA SECTION ===== */}
        <section
            class="hidden md:flex flex-col md:flex-row items-center justify-between p-12 bg-surface-dark border border-gray-800 rounded-[2rem] shadow-xl text-white mt-8"
        >
            <div class="flex flex-col max-w-xl">
                <h3 class="text-3xl font-black text-primary mb-3">
                    Reserve seu espaço na agenda
                </h3>
                <p class="text-gray-300 text-lg">
                    Sem compromisso! Fale conosco agora mesmo para rodarmos um
                    diagnóstico rápido e entender qual o melhor caminho para
                    começarmos a crescer juntos.
                </p>
            </div>

            <a
                href="https://wa.me/555191305583?text=Ol%C3%A1%21%20Estava%20no%20site%20da%20Sigel%20e%20gostaria%20de%20solicitar%20um%20diagn%C3%B3stico%20gratuito%20para%20o%20meu%20neg%C3%B3cio."
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 max-w-sm ml-8 bg-accent hover:bg-accent-dark text-white font-black text-lg py-5 px-8 rounded-xl shadow-lg shadow-primary/20 transition-transform hover:scale-105 active:scale-95 flex items-center justify-center gap-3"
            >
                <span>Ver Disponibilidade</span>
                <span class="material-symbols-outlined text-[24px]"
                    >calendar_today</span
                >
            </a>
        </section>
    </main>

    {/* ===== STICKY MOBILE CTA BAR ===== */}
    <div
        class="md:hidden fixed bottom-0 left-0 right-0 p-4 bg-black/95 backdrop-blur-md border-t border-gray-900 z-50 shadow-[0_-10px_30px_rgba(0,0,0,0.5)]"
    >
        <div class="w-full flex flex-col gap-2 relative">
            <a
                href="https://wa.me/555191305583?text=Ol%C3%A1%21%20Estava%20no%20site%20da%20Sigel%20e%20gostaria%20de%20solicitar%20um%20diagn%C3%B3stico%20gratuito%20para%20o%20meu%20neg%C3%B3cio."
                target="_blank"
                rel="noopener noreferrer"
                class="w-full bg-accent hover:bg-accent-dark text-white font-bold text-lg h-14 rounded-xl shadow-lg shadow-primary/25 active:scale-[0.98] transition-all flex items-center justify-center gap-2"
            >
                <span>Ver disponibilidade</span>
                <span class="material-symbols-outlined text-[20px]"
                    >calendar_today</span
                >
            </a>

            <p
                class="text-[11px] text-center text-gray-400 font-medium tracking-wide"
            >
                Sem compromisso. Apenas checagem de agenda.
            </p>
        </div>
    </div>

    {/* Shimmer Animation */}
    <style>
        @keyframes shimmer {
            0% {
                transform: translateX(-100%) skewX(-12deg);
            }
            100% {
                transform: translateX(200%) skewX(-12deg);
            }
        }

        .animate-shimmer {
            animation: shimmer 2s infinite;
        }
    </style>

    <Footer />
</Base>
