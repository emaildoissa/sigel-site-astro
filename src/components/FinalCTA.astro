---
// src/components/FinalCTA.astro
// CTA final antes do footer - sem JavaScript, apenas HTML puro
---

<section class="px-5 md:px-12 py-16 md:py-24 w-full">
    <div
        class="max-w-6xl mx-auto rounded-[2rem] bg-gradient-to-br from-[#1c1540] to-secondary text-white shadow-2xl flex flex-col md:flex-row items-center justify-between gap-8 md:gap-16 relative overflow-hidden group p-8 md:p-14 lg:p-16"
    >
        {/* Background Gradient */}
        <div
            class="absolute top-0 right-0 w-96 h-96 bg-primary/15 rounded-full blur-3xl group-hover:bg-primary/25 transition-colors duration-700 pointer-events-none"
        >
        </div>

        {/* Left Content */}
        <div
            class="relative z-10 w-full md:w-[60%] flex flex-col gap-4 md:gap-5"
        >
            <h2
                class="text-3xl md:text-5xl lg:text-5xl font-display font-bold tracking-tight leading-[1.15]"
            >
                Pronto para transformar os gargalos
                <br class="hidden md:block" />
                da sua empresa em lucro?
            </h2>

            <p class="text-text-secondary text-lg max-w-lg leading-relaxed">
                Agende um diagnóstico gratuito e descubra o plano exato para
                escalar suas vendas e automatizar seu atendimento.
            </p>
        </div>

        {/* Right CTA */}
        <div class="relative z-10 w-full md:w-[40%] flex flex-col md:items-end">
            <a
                href="https://wa.me/555191305583?text=Ol%C3%A1%21%20Estava%20no%20site%20da%20Sigel%20e%20gostaria%20de%20solicitar%20um%20diagn%C3%B3stico%20gratuito%20para%20o%20meu%20neg%C3%B3cio."
                target="_blank"
                rel="noopener noreferrer"
                class="ring-4 ring-primary/40 animate-pulse w-full md:w-auto py-5 px-8 md:px-10 bg-primary hover:bg-primary-dark text-white font-display font-bold text-lg md:text-xl rounded-xl shadow-[0_0_25px_rgba(246,94,55,0.4)] transition-all hover:scale-105 active:scale-95 flex items-center justify-center gap-3 group/btn"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    fill="currentColor"
                    viewBox="0 0 16 16"
                    class="transition-transform group-hover/btn:scale-110"
                >
                    <path
                        d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"
                    ></path>
                </svg>
                <span>Falar com um Especialista</span>
            </a>

            <p
                class="text-sm text-text-secondary mt-4 flex items-center justify-center md:justify-end gap-1 font-medium"
            >
                <svg
                    class="w-5 h-5 text-green-500"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                >
                    <path
                        d="M10.707 3.293a1 1 0 00-1.414 0l-6 6a1 1 0 101.414 1.414L9 6.414V16a1 1 0 102 0V6.414l4.293 4.293a1 1 0 001.414-1.414l-6-6z"
                    ></path>
                </svg>
                Análise 100% gratuita e confidencial.
            </p>
        </div>
    </div>
</section>
