    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-8">
      <div class="md:col-span-4 flex flex-col gap-5">
        <img
          src="/images/logo.png"
          alt="Sigel Soluções em Informática - Logo"
          width="160"
          height="160"
          class="h-20 md:h-24 w-auto object-contain"
          loading="lazy"
        />

        <p
          class="text-gray-400 text-[13px] md:text-sm leading-relaxed max-w-sm"
        >
          Soluções em desenvolvimento web, copywriting, automação e suporte
          técnico para empresas que querem crescer com estrutura.
        </p>

        <div class="flex items-center gap-3 pt-1">
          <a
            href="https://www.instagram.com/sigelconnections/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-300 hover:text-white hover:bg-white/10 hover:border-primary/40 transition-all"
          >
            <span class="material-symbols-outlined text-[18px]"
              >photo_camera</span
            >
          </a>

          <a
            href="https://www.linkedin.com/company/sigel"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-300 hover:text-white hover:bg-white/10 hover:border-primary/40 transition-all"
          >
            <span class="material-symbols-outlined text-[18px]">work</span>
          </a>

          <a
            href="https://wa.me/555191305583"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-300 hover:text-white hover:bg-[#25D366]/15 hover:border-[#25D366]/40 transition-all"
          >
            <span class="material-symbols-outlined text-[18px]">chat</span>
          </a>
        </div>
      </div>

      <div class="md:col-span-2 flex flex-col gap-4">
        <h4
          class="font-display font-black text-white text-[12px] uppercase tracking-[0.2em]"
        >
          Acesso Rápido
        </h4>
        <a
          href="/"
          class="text-gray-400 text-[13px] md:text-sm font-medium hover:text-primary transition-colors"
          >Início</a
        >
        <a
          href="/servicos"
          class="text-gray-400 text-[13px] md:text-sm font-medium hover:text-primary transition-colors"
          >Serviços</a
        >
        <a
          href="/sobre"
          class="text-gray-400 text-[13px] md:text-sm font-medium hover:text-primary transition-colors"
          >Sobre nós</a
        >
        <a
          href="/contato"
          class="text-gray-400 text-[13px] md:text-sm font-medium hover:text-primary transition-colors"
          >Entre em Contato</a
        >
      </div>

      <div class="md:col-span-3 flex flex-col gap-4">
        <h4
          class="font-display font-black text-white text-[12px] uppercase tracking-[0.2em]"
        >
          Serviços
        </h4>
        <a
          href="/servicos/web"
          class="text-gray-400 text-[13px] md:text-sm font-medium hover:text-primary transition-colors"
          >Desenvolvimento Web</a
        >
        <a
          href="/servicos/copywriting"
          class="text-gray-400 text-[13px] md:text-sm font-medium hover:text-primary transition-colors"
          >Copywriting</a
        >
        <a
          href="/automacao"
          class="text-gray-400 text-[13px] md:text-sm font-medium hover:text-primary transition-colors"
          >Automação</a
        >
        <a
          href="/servicos/hardware"
          class="text-gray-400 text-[13px] md:text-sm font-medium hover:text-primary transition-colors"
          >Hardware & Suporte</a
        >
      </div>

      <div class="md:col-span-3 flex flex-col gap-4">
        <h4
          class="font-display font-black text-white text-[12px] uppercase tracking-[0.2em]"
        >
          Contato
        </h4>

        <div class="flex flex-col gap-2 text-[13px] md:text-sm text-gray-400">
          <p class="leading-relaxed">
            Av. Icaraí, 1428 - Cristal<br />
            Porto Alegre - RS
          </p>

          <a
            href="mailto:contato@sigelinformatica.com.br"
            class="hover:text-primary transition-colors"
          >
            contato@sigelinformatica.com.br
          </a>

          <a
            href="https://wa.me/555191305583"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors"
          >
            (51) 991305-583
          </a>

          <a
            href="https://wa.me/555193257923"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-colors"
          >
            (51) 99325-7923
          </a>
        </div>
      </div>
    </div>

    <div
      class="mt-10 pt-6 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-3"
    >
      <p class="text-gray-500 text-[12px] font-medium text-center md:text-left">
        © {year} Sigel Soluções em Informática. Todos os direitos reservados.
      </p>

      <div class="flex items-center gap-4 text-[11px] text-gray-500">
        <span>Porto Alegre • Brasil</span>
        <span class="hidden md:inline">•</span>
        <span>Atendimento remoto em todo o Brasil</span>
      </div>
    </div>
  </div>
</footer>

<div
  class="fixed bottom-24 md:bottom-8 right-6 md:right-8 z-[60] flex flex-col items-end gap-3"
>
  {/* Tooltip */}
  <div
    class="opacity-0 group-hover:opacity-100 transition-opacity bg-gray-900 text-white text-xs font-semibold px-3 py-1.5 rounded-lg shadow-lg whitespace-nowrap pointer-events-none hidden md:block"
    id="wpp-tooltip"
  >
    Fale conosco
  </div>

  {/* Botão */}
  <div class="relative group">
    {/* Anel animado externo */}
    <span
      class="absolute inset-0 rounded-full bg-[#25D366] animate-ping opacity-30"
    ></span>

    <a
      href="https://wa.me/555191305583"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Falar no WhatsApp"
      class="relative flex items-center justify-center w-14 md:w-16 h-14 md:h-16 bg-[#25D366] hover:bg-[#20bd5a] text-white rounded-full shadow-2xl shadow-green-500/50 transition-all duration-300 hover:scale-110 active:scale-95"
      onmouseenter="document.getElementById('wpp-tooltip').style.opacity='1'"
      onmouseleave="document.getElementById('wpp-tooltip').style.opacity='0'"
    >
      {/* Logo oficial do WhatsApp */}
      <svg
        viewBox="0 0 32 32"
        xmlns="http://www.w3.org/2000/svg"
        class="w-8 h-8 md:w-9 md:h-9"
        fill="white"
      >
        <path
          d="M16 .5C7.437.5.5 7.437.5 16c0 2.72.707 5.404 2.05 7.773L.5 31.5l8.033-2.02A15.45 15.45 0 0 0 16 31.5C24.563 31.5 31.5 24.563 31.5 16S24.563.5 16 .5zm0 28.3a12.73 12.73 0 0 1-6.494-1.78l-.465-.277-4.768 1.198 1.24-4.647-.304-.477A12.752 12.752 0 1 1 16 28.8z"
        ></path>
        <path
          d="M22.003 18.948c-.31-.155-1.836-.904-2.12-.005-.284.9-.284.004-1.015 1.014-.284.31-.568.348-.878.193a11.02 11.02 0 0 1-5.513-4.819c-.31-.542.31-.581.878-1.704.155-.31.077-.58-.038-.735-.116-.155-1.04-2.503-1.427-3.43-.374-.9-.762-.775-1.04-.79-.269-.013-.58-.016-.89-.016-.31 0-.813.116-1.24.58-.426.465-1.626 1.588-1.626 3.872s1.665 4.493 1.897 4.803c.232.31 3.275 4.999 7.936 7.016 4.662 2.016 4.662 1.34 5.502 1.262.84-.077 2.712-1.108 3.097-2.18.387-1.07.387-1.987.271-2.18-.116-.193-.425-.31-.735-.464z"
        ></path>
      </svg>
    </a>
  </div>
</div>
