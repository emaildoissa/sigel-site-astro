---
// src/components/Footer.astro
// Footer com navegação, endereço e botão flutuante WhatsApp
---

<footer
    class="bg-black border-t border-gray-800 py-12 md:py-16 px-5 md:px-12 w-full"
>
    <div class="max-w-7xl mx-auto flex flex-col gap-10 md:gap-16">
        {/* Main Footer Content */}
        <div class="flex flex-col md:flex-row justify-between gap-10">
            {/* Logo Section */}
            <div class="md:max-w-sm">
                <div class="flex items-center gap-3 mb-5">
                    <img
                        src="/logo.png"
                        alt="Sigel Soluções em Informática - Logo"
                        width="96"
                        height="96"
                        class="h-20 md:h-24 object-contain"
                        loading="lazy"
                    />
                </div>
            </div>

            {/* Links Section */}
            <div class="grid grid-cols-2 md:grid-cols-3 gap-10 md:gap-20">
                {/* Quick Access */}
                <div class="flex flex-col gap-4">
                    <h4
                        class="font-display font-black text-white text-base uppercase tracking-wider"
                    >
                        Acesso Rápido
                    </h4>
                    <a
                        href="/"
                        class="text-gray-400 text-base font-medium hover:text-primary transition-colors"
                    >
                        Início
                    </a>
                    <a
                        href="/servicos"
                        class="text-gray-400 text-base font-medium hover:text-primary transition-colors"
                    >
                        Serviços
                    </a>
                    <a
                        href="/sobre"
                        class="text-gray-400 text-base font-medium hover:text-primary transition-colors"
                    >
                        Sobre nós
                    </a>
                    <a
                        href="/contato"
                        class="text-gray-400 text-base font-medium hover:text-primary transition-colors"
                    >
                        Entre em Contato
                    </a>
                </div>

                {/* Social Media */}
                <div class="flex flex-col gap-4">
                    <h4
                        class="font-display font-black text-white text-base uppercase tracking-wider"
                    >
                        Mídias Sociais
                    </h4>
                    <a
                        href="https://www.instagram.com/sigelconnections/"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-gray-400 text-base font-medium hover:text-primary transition-colors"
                    >
                        Instagram
                    </a>
                    <a
                        href="https://www.linkedin.com/company/sigel"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-gray-400 text-base font-medium hover:text-primary transition-colors"
                    >
                        LinkedIn
                    </a>
                </div>

                {/* Address */}
                <div class="col-span-2 md:col-span-1 flex flex-col gap-4">
                    <h4
                        class="font-display font-black text-white text-base uppercase tracking-wider"
                    >
                        Endereço
                    </h4>
                    <p
                        class="text-gray-400 text-base font-medium leading-relaxed"
                    >
                        Av. Icaraí, 1428 - Cristal<br />
                        Porto Alegre - RS
                    </p>
                </div>
            </div>
        </div>

        {/* Divider */}
        <div class="border-t border-gray-800"></div>

        {/* Copyright */}
        <div class="flex flex-col items-center justify-between gap-4">
            <p class="text-gray-500 text-sm font-medium text-center">
                © {new Date().getFullYear()} Sigel Soluções em Informática. Todos
                os direitos reservados.
            </p>
        </div>
    </div>
</footer>

{/* Floating WhatsApp Button */}
<div class="fixed bottom-24 md:bottom-8 right-6 md:right-8 z-[60]">
    <a
        href="https://wa.me/555191305583"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Falar no WhatsApp"
        class="flex items-center justify-center w-14 md:w-16 h-14 md:h-16 bg-[#25D366] text-white rounded-full shadow-2xl shadow-green-500/40 hover:bg-[#20bd5a] transition-all hover:scale-110 active:scale-95 group"
    >
        <svg
            fill="white"
            class="w-8 h-8 md:w-9 md:h-9 group-hover:animate-pulse"
            viewBox="0 0 256 256"
            xmlns="http://www.w3.org/2000/svg"
        >
            <path
                d="M128,24A104,104,0,0,0,36.18,176.88L24.83,210.93a16,16,0,0,0,20.24,20.24l34.05-11.35A104,104,0,1,0,128,24Zm0,192a87.87,87.87,0,0,1-44.06-11.81,8,8,0,0,0-6.54-.67L40,216,52.47,178.6a8,8,0,0,0-.66-6.54A88,88,0,1,1,128,216Zm59.51-66.21c-2.31-4.9-10.74-8.86-15.07-9.45a33.64,33.64,0,0,0-12-1.09,12.72,12.72,0,0,0-4,1.15c-1.32.57-4.14,2.29-6.3,5-7.33,9.27-16.14,9.66-22.3,9.45a33.37,33.37,0,0,1-13.43-3.61A87.54,87.54,0,0,1,96,134a34.78,34.78,0,0,1-8.58-13.68c-.68-2.22-3.13-11.66,4.6-20.14,2.37-2.6,4.82-3.83,6.34-4.35a11.63,11.63,0,0,0,4-1.2,16.5,16.5,0,0,0,2.16-1.55c3.55-3.07,3.13-6.57,2.83-8.32-.57-3.32-3.41-13.78-6.19-18.78-3.08-5.55-7-5.32-9.49-5.18-5.26.29-10.51,2.5-13.78,6.07-8.31,9-10.23,24.36-4.52,40.15,6.54,18.06,23.33,40.54,52.88,52.89,20.65,8.63,28.62,5.2,33.58,3.72a28,28,0,0,0,14-9.35C175.78,152.19,189.82,154.67,187.51,149.79Z"
            ></path>
        </svg>
    </a>
</div>
