---
export interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="group relative overflow-hidden rounded-2xl bg-surface-dark p-6 shadow-md transition-all hover:shadow-xl hover:-translate-y-2">
  
  {/* Dotted Background Pattern */}
  <div
    class="absolute inset-0 opacity-20"
    style="background-image: radial-gradient(#ffcf3d 1.5px, transparent 1.5px); background-size: 24px 24px;"
  ></div>

  {/* Content */}
  <div class="relative z-10 flex flex-col h-full gap-4">
    
    {/* Icon */}
    <div class="flex h-14 w-14 md:h-16 md:w-16 items-center justify-center rounded-xl bg-accent text-white shadow-lg shadow-accent/20 group-hover:scale-110 transition-transform">
      <span class="material-symbols-outlined text-[32px] md:text-[36px]">{icon}</span>
    </div>

    {/* Title */}
    <h3 class="text-xl md:text-2xl font-bold text-white mb-2">{title}</h3>

    {/* Description */}
    <p class="text-gray-400 text-sm md:text-base leading-relaxed flex-1">{description}</p>
  </div>
</div>